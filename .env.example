# ── MSG91 OTP Widget (recommended) ──────────────────────────────────────────
# 1. Create widget in MSG91 dashboard → OTP → your widget
# 2. Create a Widget Token (NOT the auth key) → use as VITE_MSG91_TOKEN_AUTH
# 3. Get Auth Key from dashboard → use as MSG91_AUTH_KEY (server only)

VITE_MSG91_WIDGET_ID=36676b6b4c6c303131343331
VITE_MSG91_TOKEN_AUTH=your_widget_token_here

# Server-side only — verifies the access token after client OTP verification
MSG91_AUTH_KEY=your_msg91_auth_key_here

# Optional: standalone OTP server port when running `npm run otp-server` (default 8787)
# OTP_SERVER_PORT=8787

# Optional: if OTP API runs on a different host in production
# VITE_OTP_API_URL=https://your-otp-api.example.com

# Optional: verify superadmin login in npm run supabase:check-member-auth (local only — do not commit)
# ADMIN_TEST_PASSWORD=your-super-admin-password-here

# ── Supabase (optional — enables cloud sync for members, bulletins, forum, admin) ──
# 1. Create a project at https://supabase.com
# 2. Run supabase/migrations/001_initial_schema.sql in SQL Editor
# 3. Copy Project URL and anon public key from Settings → API

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
VITE_SUPABASE_USE_PROXY=false

# ── Vercel deployment ───────────────────────────────────────────────────────
# Add the same variables in Vercel → Project → Settings → Environment Variables.
# Do NOT add SUPABASE_SERVICE_ROLE_KEY unless you add a server-side proxy.
# MSG91_AUTH_KEY is server-only (no VITE_ prefix).
